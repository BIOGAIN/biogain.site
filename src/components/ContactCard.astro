---
/**
 * ContactCard Component
 *
 * An embeddable card that surfaces a single team member as a point of contact.
 * Pulls data from the "team" content collection — no duplication of team info.
 *
 * The card is filled with the BIOGAIN brand gradient (navy → teal → green) as
 * its full background. All text and icons render in white for legibility.
 *
 * Embeddable in .mdx files — import the component at the top of your .mdx file:
 *   import ContactCard from "@/components/ContactCard.astro";
 * Then use it inline:
 *   <ContactCard memberId="alexandra-jiricka-purrer" intro="Get in touch" />
 *
 * @example
 * ```astro
 * <ContactCard
 *   memberId="alexandra-jiricka-purrer"
 *   intro="Questions about BIOGAIN? Reach out to our project coordinator."
 * />
 * ```
 *
 * @props
 * - memberId   — The team member's `id` as defined in team.yaml (required)
 * - intro      — Short call-to-action line shown above the name (optional).
 *                Defaults to "Get in touch".
 */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { withBase } from "@/lib/utils";

interface Props {
  /** The `id` field from team.yaml, e.g. "alexandra-jiricka-purrer" */
  memberId: string;
  /** Short intro/CTA line shown at the top of the card. */
  intro?: string;
}

const { memberId, intro = "Get in touch" } = Astro.props;

// Fetch the matching team member
const allMembers = await getCollection("team");
const member = allMembers.find((m) => m.id === memberId);

if (!member) {
  throw new Error(
    `ContactCard: no team member found with id "${memberId}". ` +
      `Check src/data/team.yaml for valid ids.`
  );
}

const { name, affiliation, affiliationShort, workPackages } = member.data;

// ---- Photo lookup (same pattern as TeamMemberCard) --------------------------
const photoGlob = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/team/*.{webp,jpg,jpeg,png}",
  { eager: true }
);

const extensions = ["webp", "jpg", "jpeg", "png"];
let photoSrc: ImageMetadata | undefined;
for (const ext of extensions) {
  const key = `/src/assets/team/${memberId}.${ext}`;
  if (photoGlob[key]) {
    photoSrc = photoGlob[key].default;
    break;
  }
}

// ---- Initials fallback ------------------------------------------------------
function getInitials(fullName: string): string {
  const parts = fullName.trim().split(/\s+/);
  if (parts.length === 1) return parts[0].charAt(0).toUpperCase();
  return (
    parts[0].charAt(0).toUpperCase() +
    parts[parts.length - 1].charAt(0).toUpperCase()
  );
}

const initials = getInitials(name);

// ---- Role badges (only named roles — coordinator, WP lead/co-lead) ----------
const namedRoles = workPackages.filter((w) => w.role);

// ---- Team page deep-link ----------------------------------------------------
const teamHref = withBase(`/team/#${memberId}`);
---

<div
  class="contact-card relative rounded-2xl overflow-hidden shadow-[0_20px_15px_-5px_rgb(0_0_0_/_0.12),0_8px_6px_-6px_rgb(0_0_0_/_0.12)] not-prose"
  data-animate="scale"
>
  <div class="relative p-6 sm:p-8">

    <div class="relative flex flex-col sm:flex-row items-start sm:items-center gap-5">

      <!-- Photo or initials placeholder -->
      <div
        class="contact-card-photo shrink-0 rounded-full overflow-hidden"
        style="width: 88px; height: 88px;"
        aria-hidden="true"
      >
        {photoSrc ? (
          <Image
            src={photoSrc}
            alt={`Photo of ${name}`}
            width={88}
            height={88}
            densities={[1.5, 2]}
            quality={85}
            class="w-full h-full object-cover"
          />
        ) : (
          <div
            class="w-full h-full flex items-center justify-center font-semibold text-xl text-white"
            style="background: rgba(255,255,255,0.2);"
          >
            {initials}
          </div>
        )}
      </div>

      <!-- Text content -->
      <div class="flex-1 min-w-0">

        <!-- CTA intro line -->
        <p class="text-sm font-medium text-white/80 mb-1">{intro}</p>

        <!-- Name — white on gradient background -->
        <h3 class="text-2xl font-bold leading-tight mb-0.5 text-white">{name}</h3>

        <!-- Affiliation -->
        <p class="text-base text-white/80">
          {affiliationShort ? `${affiliationShort} — ${affiliation}` : affiliation}
        </p>

        <!-- Role badges — outlined chips on the gradient background -->
        {namedRoles.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-2">
            {namedRoles.map(({ wp, role }) => (
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold text-white border border-white/60 bg-transparent">
                {role === "standalone"
                  ? wp
                  : `${wp} ${role!.charAt(0).toUpperCase()}${role!.slice(1)}`}
              </span>
            ))}
          </div>
        )}

      </div>

      <!-- Team page link as outlined button (floated right) -->
      <div class="shrink-0 sm:ml-auto mt-4 sm:mt-0">
        <a
          href={teamHref}
          class="contact-card-button inline-flex items-center px-4 py-2 rounded-md text-sm font-medium border border-white hover:bg-white/10 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-transparent"
          aria-label={`View ${name}'s full profile on the team page`}
        >
          View full profile &rarr;
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  /* Full gradient background — navy → teal → green */
  .contact-card {
    background: linear-gradient(
      to right,
      var(--color-brand-navy),
      var(--color-brand-teal),
      var(--color-brand-green)
    );
  }

  /* Photo ring: semi-transparent white so it reads on any gradient position */
  .contact-card-photo {
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.5);
  }

  /* Prevent prose styles from overriding the card's h3 and links */
  .contact-card h3 {
    background-image: none !important;
    background-clip: unset !important;
    -webkit-background-clip: unset !important;
    color: white !important;
    -webkit-text-fill-color: white !important;
    padding-bottom: 0;
  }

  .contact-card a {
    text-decoration: none;
  }

  /* Force white text on the button — overrides prose link colors that leak
     through the `not-prose` boundary in some MDX contexts. */
  .contact-card-button,
  .contact-card-button:hover,
  .contact-card-button:focus {
    color: white;
  }
</style>
