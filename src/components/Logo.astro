---
/**
 * Logo Component
 *
 * Biogain brand logo.
 * Used consistently across Header, Footer, and Auth layouts.
 *
 * @example
 * ```astro
 * <Logo />
 * <Logo size="lg" />
 * ```
 */
import BIOGAINLogo from '../assets/biogain_logo.svg';
import { withBase } from '@/lib/utils';

interface Props {
  /** Size variant */
  size?: 'sm' | 'md' | 'lg';
  /** Additional CSS classes */
  class?: string;
}

const { size = 'md', class: className = '' } = Astro.props;

const heightClasses = {
  sm: 'h-12',
  md: 'h-16',
  lg: 'h-20',
};
---

<a href={withBase("/")} aria-label="BIOGAIN — Go to homepage" class:list={['flex items-center', className]}>
  <BIOGAINLogo
    aria-hidden="true"
    class:list={[heightClasses[size], 'w-auto']}
  />
</a>
