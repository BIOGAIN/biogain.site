---
/**
 * Footer Component
 *
 * Unified footer with boxed and fullWidth variants.
 * Contains navigation links, resources, and creator info.
 *
 * @example
 * ```astro
 * <Footer />
 * <Footer variant="fullWidth" />
 * ```
 */
import Logo from './Logo.astro';
import { withBase } from '@/lib/utils';

interface Props {
  /** Layout variant - boxed (default) or fullWidth */
  variant?: 'boxed' | 'fullWidth';
}

const { variant = 'boxed' } = Astro.props;

const footerLinks = {
  site: [
    { href: '/', label: 'Home' },
    { href: '/about', label: 'About' },
    { href: '/team', label: 'Team' },
    { href: '/news', label: 'News' },
    { href: '/search', label: 'Search' },
  ],
  output: [
    { href: '/output/publications', label: 'Publications' },
    { href: '/output/conferences', label: 'Conferences' },
    { href: '/output/press-coverage', label: 'Press coverage' },
  ],
};

// Funding acknowledgement (task 1.5).
// BIOGAIN is funded by the five partners' national funding organisations through the
// 2024-2025 BiodivTransform call of Biodiversa+. Rendered HiRAD-style as
// "Funder name (ABBR grant-number)". `grant` is intentionally empty until each partner
// supplies the number from its own grant agreement — when empty the parenthetical shows
// just the abbreviation, never a placeholder number.
// `lang` is set for non-English funder names so the browser can hyphenate them (hyphens:auto
// needs a matching lang); e.g. "Forschungs-gemein-schaft" wraps only when the column is tight.
const fundingPartners: { funder: string; abbr: string; grant?: string; lang?: string }[] = [
  { funder: 'Austrian Science Fund', abbr: 'FWF', grant: '10.55776/KIN1274625' },
  { funder: 'Federal Ministry of Research, Technology and Space (BMFTR) is funding this project within the framework of the Strategy &ldquo;Research for Sustainability&rdquo;', abbr: 'FONA', grant: '03LWU0014', lang: 'en' },
  { funder: 'National Science Centre Poland', abbr: 'NCN', grant: '2025/07/Y/HS4/00125' },
  { funder: 'Innovation Fund Denmark', abbr: 'IFD', grant: '' },
  { funder: 'Dutch Research Council', abbr: 'NWO', grant: 'EP.1512.25.04' },
];

// Pre-build the funder list as one HTML string so it renders identically in dev and prod
// (Astro's dev source-mapping otherwise injects whitespace between sibling spans, e.g. a
// stray space before each comma). German names get lang + hyphens-auto for responsive
// hyphenation; short abbreviations simply never hit a hyphenation point.
const fundingOrgsHtml = fundingPartners
  .map((p) => {
    const label = `${p.funder} (${p.grant ? `${p.abbr}, ${p.grant}` : p.abbr})`;
    return p.lang ? `<span lang="${p.lang}" class="hyphens-auto">${label}</span>` : label;
  })
  .map((item, i, arr) => (i === 0 ? item : (i === arr.length - 1 ? ', and ' : ', ') + item))
  .join('');

const containerClass =
  variant === 'fullWidth' ? 'w-full px-4' : 'container max-w-5xl mx-auto px-4 sm:px-6';
---

<footer class="border-t bg-background">
  <div class:list={[containerClass, 'py-12']}>
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <Logo />
        <p class="mt-4 text-sm text-muted-foreground">
          Enabling biodiversity-positive transformation of energy planning towards climate neutrality.
        </p>
      </div>

      <!-- BIOGAIN -->
      <div>
        <h3 class="font-semibold mb-4">BIOGAIN</h3>
        <ul class="space-y-2">
          {
            footerLinks.site.map((link: { href: string; label: string }) => (
              <li>
                <a
                  href={withBase(link.href)}
                  class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Output -->
      <div>
        <h3 class="font-semibold mb-4">Output</h3>
        <ul class="space-y-2">
          {
            footerLinks.output.map((link: { href: string; label: string }) => (
              <li>
                <a
                  href={withBase(link.href)}
                  class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Funding (task 1.5) -->
      <div class="col-span-2 md:col-span-1">
        <h3 class="font-semibold mb-4">Funding</h3>
        <p class="text-sm text-muted-foreground break-words">
          BIOGAIN is funded by Biodiversa+, the European Biodiversity Partnership under the <a
            href="https://www.biodiversa.eu/2024/06/11/2024-2025-joint-call/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary underline underline-offset-4 hover:text-primary/80 transition-colors"
            >2024 - 2025 BiodivTransform</a
          > joint call. It was co-funded by the European Commission (GA No. 101052342) and the following funding organisations: <Fragment set:html={fundingOrgsHtml} />. See the
          project page on the <a
            href="https://www.biodiversa.eu/2026/04/03/biogain/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary underline underline-offset-4 hover:text-primary/80 transition-colors"
            >Biodiversa+</a
          > website.
        </p>
        <a
          href="https://www.biodiversa.eu/2026/04/03/biogain/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="BIOGAIN on Biodiversa+"
          class="mt-4 inline-flex transition-opacity hover:opacity-80"
        >
          <img
            src={withBase('/logos/biodiversa-plus.svg')}
            alt="Biodiversa+"
            width="214"
            height="55"
            class="h-10 w-auto"
            loading="lazy"
            decoding="async"
          />
        </a>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-8 border-t pt-8 text-center text-sm text-muted-foreground">
      <p>&copy; {new Date().getFullYear()} BIOGAIN partners - Content on this site is licensed under a <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener noreferrer" class="text-primary underline underline-offset-4 hover:text-primary/80 transition-colors">CC BY 4.0 License</a>.</p>
      <p>Notice a mistake? Open a <a href="https://github.com/BIOGAIN/biogain.site/issues" target="_blank" rel="noopener noreferrer" class="text-primary underline underline-offset-4 hover:text-primary/80 transition-colors">GitHub issue</a>.</p>
    </div>
  </div>
</footer>
