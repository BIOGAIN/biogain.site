---
/**
 * Latest News Section Component
 *
 * Displays the three most recent news posts from the "news" content collection,
 * sorted by date descending. Includes a link to the full news listing.
 *
 * @example
 * ```astro
 * <LatestNews
 *   title="Latest news"
 *   viewAllLabel="All news"
 * />
 * ```
 */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { getNewsUrl } from "@/lib/news";
import { withBase } from "@/lib/utils";

interface Props {
  title?: string;
  viewAllLabel?: string;
}

const { title = "Latest news", viewAllLabel = "All news" } = Astro.props;

const allPosts = await getCollection("news");
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const gridLayoutClass =
  recentPosts.length === 1
    ? "grid-cols-1 max-w-sm mx-auto"
    : recentPosts.length === 2
      ? "sm:grid-cols-2 max-w-2xl mx-auto"
      : "sm:grid-cols-2 md:grid-cols-3";

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<section class="pt-4 md:pt-8 pb-10 md:pb-16 px-6">
  <div class="container max-w-5xl mx-auto">
    <div class="flex items-end justify-between mb-12" data-animate>
      <h2 class="text-3xl font-bold leading-[1.1] sm:text-3xl md:text-5xl">
        {title}
      </h2>
      <a
        href={withBase("/news")}
        class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors hidden sm:inline-flex items-center gap-1"
      >
        {viewAllLabel}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m9 18 6-6-6-6"></path>
        </svg>
      </a>
    </div>

    <div class:list={["grid gap-px bg-border overflow-hidden rounded-xl border shadow-lg", gridLayoutClass]}>
      {
        recentPosts.map((post, index) => (
          <article data-animate data-delay={String(index + 1)}>
            <a
              href={withBase(getNewsUrl(post))}
              class="news-card group flex flex-col h-full bg-card"
            >
              {/* Image area — flush to all edges, 4:3 aspect ratio, no padding */}
              <div class="w-full aspect-[3/2] bg-gradient-to-br from-primary/20 via-primary/10 to-transparent relative overflow-hidden shrink-0">
                {post.data.image ? (
                  <Image
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="48"
                      height="48"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="text-primary/40"
                    >
                      <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect>
                      <circle cx="9" cy="9" r="2"></circle>
                      <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
                    </svg>
                  </div>
                )}
              </div>

              {/* Text area — brand gradient sweep on hover, matching a.bg-primary in globals.css */}
              <div class="news-card-text flex flex-col flex-1 px-8 py-10 relative overflow-hidden">
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="news-card-muted text-xs text-muted-foreground mb-4 relative z-10"
                >
                  {formatDate(post.data.pubDate)}
                </time>
                <h3 class="news-card-title text-lg font-semibold leading-snug mb-3 relative z-10 flex-1">
                  {post.data.title}
                </h3>
                <p class="news-card-muted text-sm text-muted-foreground line-clamp-2 relative z-10">
                  {post.data.description}
                </p>
              </div>
            </a>
          </article>
        ))
      }
    </div>

    <div class="mt-8 flex justify-center sm:hidden">
      <a
        href={withBase("/news")}
        class="inline-flex items-center gap-1 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
      >
        {viewAllLabel}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m9 18 6-6-6-6"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  /*
   * Brand gradient sweep — mirrors the primary button animation in globals.css:
   *   a.bg-primary / button.bg-primary
   *   gradient: navy → navy → teal → green (300% wide)
   *   slides from right to left on hover over 0.6s ease
   */
  .news-card-text {
    background-color: var(--color-card);
  }

  .news-card:hover .news-card-text {
    animation: news-card-brand-sweep 0.4s linear forwards;
  }

  @keyframes news-card-brand-sweep {
    0%   { background-color: var(--color-card); }
    33%  { background-color: var(--color-brand-green); }
    50%  { background-color: color-mix(in oklch, var(--color-brand-green), var(--color-brand-teal)); }
    66%  { background-color: var(--color-brand-teal); }
    83%  { background-color: color-mix(in oklch, var(--color-brand-teal), var(--color-brand-navy)); }
    100% { background-color: var(--color-brand-navy); }
  }

  /* Muted text transitions to a light tint of the gradient (legible on dark bg) */
  .news-card-muted {
    transition: color 0.4s linear;
  }

  .news-card:hover .news-card-muted {
    color: oklch(98% 0 0 / 0.7);
  }

  /* Title shows the brand gradient (navy → teal → green) by default,
     matching the global h1/h2 treatment, and transitions to white on hover. */
  .news-card-title {
    background-image: linear-gradient(
      to right,
      var(--color-brand-navy),
      var(--color-brand-teal),
      var(--color-brand-green)
    );
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    padding-bottom: 0.1em;
    transition:
      color 0.4s linear,
      -webkit-text-fill-color 0.4s linear;
  }

  .news-card:hover .news-card-title {
    color: oklch(98% 0 0);
    -webkit-text-fill-color: oklch(98% 0 0);
  }
</style>
