---
/**
 * Latest News Section Component
 *
 * Displays the three most recent news posts from the "news" content collection,
 * sorted by date descending. Includes a link to the full news listing.
 *
 * @example
 * ```astro
 * <LatestNews
 *   title="Latest news"
 *   viewAllLabel="All news"
 * />
 * ```
 */
import { getCollection } from "astro:content";
import { getNewsUrl } from "@/lib/news";

interface Props {
  title?: string;
  viewAllLabel?: string;
}

const { title = "Latest news", viewAllLabel = "All news" } = Astro.props;

const allPosts = await getCollection("news");
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<section class="py-20 px-6">
  <div class="container max-w-5xl mx-auto">
    <div class="flex items-end justify-between mb-12" data-animate>
      <h2 class="text-3xl font-bold leading-[1.1] sm:text-3xl md:text-5xl">
        {title}
      </h2>
      <a
        href="/news"
        class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors hidden sm:inline-flex items-center gap-1"
      >
        {viewAllLabel}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m9 18 6-6-6-6"></path>
        </svg>
      </a>
    </div>

    <div class="grid gap-px sm:grid-cols-2 md:grid-cols-3 bg-border overflow-hidden rounded-xl border shadow-lg">
      {
        recentPosts.map((post, index) => (
          <article data-animate data-delay={String(index + 1)}>
            <a
              href={getNewsUrl(post)}
              class="group flex flex-col h-full bg-card px-8 py-10 hover:bg-accent/30 transition-colors"
            >
              <time
                datetime={post.data.pubDate.toISOString()}
                class="text-xs text-muted-foreground mb-4"
              >
                {formatDate(post.data.pubDate)}
              </time>
              <h3 class="text-lg font-semibold leading-snug mb-3 group-hover:text-primary transition-colors flex-1">
                {post.data.title}
              </h3>
              <p class="text-sm text-muted-foreground line-clamp-2">
                {post.data.description}
              </p>
            </a>
          </article>
        ))
      }
    </div>

    <div class="mt-8 flex justify-center sm:hidden">
      <a
        href="/news"
        class="inline-flex items-center gap-1 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
      >
        {viewAllLabel}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m9 18 6-6-6-6"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
