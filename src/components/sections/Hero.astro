---
/**
 * Hero Section Component
 *
 * A large, centered hero section with title, subtitle, and CTA buttons.
 * Optionally accepts a background image (src/assets/) rendered via <Image /> as an
 * absolutely-positioned layer with a dark gradient overlay for text contrast.
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BiogainLogo from "@/assets/biogain_logo.svg";
import { withBase } from "@/lib/utils";

interface Props {
  title: string;
  subtitle: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
  backgroundImage?: ImageMetadata;
  /** Optional photo credit, overlaid on the bottom-right of the background image */
  backgroundCredit?: string;
  /** Render the Biogain logo SVG in place of the title text */
  titleAsLogo?: boolean;
}

const { title, subtitle, primaryCta, secondaryCta, backgroundImage, backgroundCredit, titleAsLogo = false } = Astro.props;
---

<section class="min-h-[33.6vh] md:min-h-[42vh] flex items-start py-[6.4vh] md:py-[9.6vh] relative overflow-hidden">
  <!-- Optional full-bleed photo background -->
  {backgroundImage && (
    <>
      <Image
        src={backgroundImage}
        alt=""
        aria-hidden="true"
        widths={[768, 1280, 1920]}
        sizes="100vw"
        loading="eager"
        data-hero-parallax
        class="absolute inset-x-0 -top-[20%] w-full h-[calc(100%+16rem)] object-cover object-[center_35%] z-0 pointer-events-none will-change-transform"
      />
      {/* Overlay temporarily disabled — uncomment to restore
      <div class="absolute inset-0 bg-gradient-to-b from-white/30 via-white/20 to-white/40 z-[1] pointer-events-none" aria-hidden="true" />
      */}
      {backgroundCredit && (
        <span data-hero-credit class="absolute bottom-2 right-3 z-[2] text-xs text-white/80 [text-shadow:0_1px_2px_rgb(0_0_0_/_0.6)] pointer-events-none select-none transition-opacity duration-300">
          {backgroundCredit}
        </span>
      )}
    </>
  )}
  <div class="container max-w-5xl mx-auto flex flex-col items-center gap-6 text-center relative z-10" data-animate="fade">
    <h1 class:list={[
      titleAsLogo
        ? "flex justify-center max-w-5xl"
        : "text-5xl font-bold leading-tight tracking-tight md:text-7xl lg:text-8xl lg:leading-[1.1] max-w-5xl",
    ]}>
      {titleAsLogo ? (
        <>
          <BiogainLogo
            aria-hidden="true"
            class="h-24 md:h-32 lg:h-40 w-auto halo-pulse"
          />
          <span class="sr-only">{title}</span>
        </>
      ) : (
        title
      )}
    </h1>
    <p class="max-w-[640px] text-2xl md:text-3xl font-semibold pb-[0.1em] [background-image:linear-gradient(to_right,var(--color-brand-navy),var(--color-brand-teal),var(--color-brand-green))] bg-clip-text text-transparent halo-pulse" set:html={subtitle} />
    <div class="flex flex-col sm:flex-row gap-4 mt-4">
      {primaryCta && (
        <a
          href={withBase(primaryCta.href)}
          class="group relative inline-flex items-center justify-center whitespace-nowrap rounded-md text-base font-semibold ring-offset-background transition-all duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 bg-primary text-primary-foreground hover:bg-primary/90 hover:scale-105 h-12 px-12 shadow-lg shadow-primary/30 hover:shadow-xl hover:shadow-primary/40 overflow-hidden"
        >
          <!-- Shine effect overlay -->
          <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-in-out"></span>

          <!-- Button text -->
          <span class="relative z-10 inline-block transition-transform duration-300 group-hover:translate-x-0.5">
            {primaryCta.label}
          </span>
        </a>
      )}
      {secondaryCta && (
        <a
          href={withBase(secondaryCta.href)}
          class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-12 px-8"
        >
          {secondaryCta.label}
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .halo-pulse {
    filter: drop-shadow(0 0 1px white) drop-shadow(0 0 1px white) drop-shadow(0 0 1px white);
    animation: halo-pulse 4.5s ease-in-out infinite;
  }
  @keyframes halo-pulse {
    0%, 100% {
      filter: drop-shadow(0 0 1px white) drop-shadow(0 0 1px white) drop-shadow(0 0 1px white);
    }
    50% {
      filter: drop-shadow(0 0 2px white) drop-shadow(0 0 4px white) drop-shadow(0 0 8px rgb(255 255 255 / 0.6));
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .halo-pulse {
      animation: none;
    }
  }
</style>

<script>
  const img = document.querySelector<HTMLElement>("[data-hero-parallax]");
  const credit = document.querySelector<HTMLElement>("[data-hero-credit]");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
  // Parallax is a desktop-only enhancement: stronger effect, skipped on mobile.
  const desktop = window.matchMedia("(min-width: 768px)");

  if (img) {
    let ticking = false;
    const update = () => {
      // Stronger parallax on desktop, a gentler version on mobile, none if reduced-motion.
      const factor = reduce.matches ? 0 : desktop.matches ? -0.4 : -0.15;
      img.style.transform = `translate3d(0, ${window.scrollY * factor}px, 0)`;
      // The credit stays pinned to the frame, but the reversed parallax lifts the
      // image's bottom edge faster than the page scrolls — hide the credit once the
      // image no longer sits behind it so it never lingers over empty space.
      if (credit) {
        const covered = img.getBoundingClientRect().bottom >= credit.getBoundingClientRect().bottom;
        credit.style.opacity = covered ? "1" : "0";
      }
      ticking = false;
    };
    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    };
    update();
    window.addEventListener("scroll", onScroll, { passive: true });
    // Re-evaluate when crossing the breakpoint or toggling reduced-motion.
    desktop.addEventListener("change", update);
    reduce.addEventListener("change", update);
  }
</script>
