---
import BokuLogo from '../../assets/logos/boku-small.svg';
import TuBerlinLogo from '../../assets/logos/tuberlin-small.svg';
import AalborgLogo from '../../assets/logos/aalborg-small.svg';
import { withBase } from '@/lib/utils';

interface Props {
  title?: string;
  /**
   * "external" (default) → links go to each university's homepage in a new tab.
   * "team-affiliation"   → links go to the matching `#affiliation-<short>` anchor
   *                        on the team page so the consortium logos act as a jump
   *                        navigation into the by-affiliation view.
   */
  linkMode?: 'external' | 'team-affiliation';
  /** When true (default) renders as a bordered page section with vertical padding. */
  bordered?: boolean;
  /** Horizontal alignment of the title and logo row. Defaults to centred. */
  align?: 'center' | 'left';
}

const {
  title = 'Consortium partners',
  linkMode = 'external',
  bordered = true,
  align = 'center',
} = Astro.props;

const externalHrefs = {
  boku: 'https://boku.ac.at',
  tuberlin: 'https://www.tu.berlin',
  wroclaw: 'https://upwr.edu.pl',
  aalborg: 'https://www.aau.dk',
  utrecht: 'https://www.uu.nl',
};

const teamHrefs = {
  boku: withBase('/team#affiliation-boku'),
  tuberlin: withBase('/team#affiliation-tu-berlin'),
  wroclaw: withBase('/team#affiliation-upwr'),
  aalborg: withBase('/team#affiliation-aau'),
  utrecht: withBase('/team#affiliation-uu'),
};

const hrefs = linkMode === 'team-affiliation' ? teamHrefs : externalHrefs;
const isExternal = linkMode === 'external';
const target = isExternal ? '_blank' : undefined;
const rel = isExternal ? 'noopener noreferrer' : undefined;
---

<section class:list={[bordered && 'py-12 border-y']}>
  <div class:list={[bordered && 'container max-w-5xl mx-auto px-6']}>
    <div class="flex flex-col gap-6">
      <span
        class:list={[
          'text-sm text-muted-foreground font-semibold',
          align === 'left' ? 'text-left' : 'text-center',
        ]}
      >{title}</span>
      <div
        class:list={[
          'flex flex-nowrap sm:flex-wrap items-center gap-x-3 gap-y-6 sm:gap-x-10',
          align === 'left' ? 'justify-start sm:justify-start' : 'justify-center',
        ]}
      >
        <a
          href={hrefs.boku}
          target={target}
          rel={rel}
          aria-label="BOKU University Vienna"
          class="flex-1 min-w-0 flex items-center justify-center sm:flex-none sm:block"
        >
          <BokuLogo
            role="img"
            aria-label="BOKU University Vienna"
            class="max-h-[2.5rem] w-full h-auto object-contain sm:max-h-none sm:h-[5rem] sm:w-auto"
            shape-rendering="geometricPrecision"
          />
        </a>
        <a
          href={hrefs.tuberlin}
          target={target}
          rel={rel}
          aria-label="TU Berlin"
          class="flex-1 min-w-0 flex items-center justify-center sm:flex-none sm:block"
        >
          <TuBerlinLogo
            role="img"
            aria-label="TU Berlin"
            class="max-h-[3rem] w-full h-auto object-contain sm:max-h-none sm:h-[6rem] sm:w-auto"
            shape-rendering="geometricPrecision"
          />
        </a>
        <a
          href={hrefs.wroclaw}
          target={target}
          rel={rel}
          aria-label="Wrocław University of Environmental and Life Sciences"
          class="flex-1 min-w-0 flex items-center justify-center sm:flex-none sm:block"
        >
          <img
            src={withBase("/logos/wroclaw-small.webp")}
            alt="Wrocław University of Environmental and Life Sciences"
            class="max-h-[3.375rem] w-full h-auto object-contain sm:max-h-none sm:h-[6.75rem] sm:w-auto"
            loading="lazy"
            decoding="async"
          />
        </a>
        <a
          href={hrefs.aalborg}
          target={target}
          rel={rel}
          aria-label="Aalborg University"
          class="flex-1 min-w-0 flex items-center justify-center sm:flex-none sm:block"
        >
          <AalborgLogo
            role="img"
            aria-label="Aalborg University"
            class="max-h-[3.375rem] w-full h-auto object-contain sm:max-h-none sm:h-[6.75rem] sm:w-auto"
            shape-rendering="geometricPrecision"
          />
        </a>
        <a
          href={hrefs.utrecht}
          target={target}
          rel={rel}
          aria-label="Utrecht University"
          class="flex-1 min-w-0 flex items-center justify-center sm:flex-none sm:block"
        >
          <img
            src={withBase("/logos/utrechtuniversity-small.webp")}
            alt="Utrecht University"
            class="max-h-[3.5rem] w-full h-auto object-contain translate-y-1.5 sm:max-h-none sm:h-[7rem] sm:w-auto sm:translate-y-3"
            loading="lazy"
            decoding="async"
          />
        </a>
      </div>
    </div>
  </div>
</section>
