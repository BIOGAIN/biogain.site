---
import BokuLogo from '../../assets/logos/boku-small.svg';
import TuBerlinLogo from '../../assets/logos/tuberlin-small.svg';
import AalborgLogo from '../../assets/logos/aalborg-small.svg';

interface Props {
  title?: string;
}

const { title = 'Consortium partners' } = Astro.props;
---

<section class="py-12 border-y">
  <div class="container max-w-5xl mx-auto px-6">
    <div class="flex flex-col gap-6">
      <span class="text-sm text-muted-foreground font-semibold text-center">{title}</span>
      <div class="flex flex-wrap justify-center items-center gap-x-10 gap-y-6">
        <a href="https://boku.ac.at" target="_blank" rel="noopener noreferrer" aria-label="BOKU University Vienna">
          <BokuLogo
            role="img"
            aria-label="BOKU University Vienna"
            class="h-[5rem] w-auto"
            shape-rendering="geometricPrecision"
          />
        </a>
        <a href="https://www.tu.berlin" target="_blank" rel="noopener noreferrer" aria-label="TU Berlin">
          <TuBerlinLogo
            role="img"
            aria-label="TU Berlin"
            class="h-[6rem] w-auto"
            shape-rendering="geometricPrecision"
          />
        </a>
        <a href="https://upwr.edu.pl" target="_blank" rel="noopener noreferrer" aria-label="Wrocław University of Environmental and Life Sciences">
          <img
            src="/logos/wroclaw-small.webp"
            alt="Wrocław University of Environmental and Life Sciences"
            class="h-[6.75rem] w-auto"
            loading="lazy"
            decoding="async"
          />
        </a>
        <a href="https://www.aau.dk" target="_blank" rel="noopener noreferrer" aria-label="Aalborg University">
          <AalborgLogo
            role="img"
            aria-label="Aalborg University"
            class="h-[6.75rem] w-auto"
            shape-rendering="geometricPrecision"
          />
        </a>
        <a href="https://www.uu.nl" target="_blank" rel="noopener noreferrer" aria-label="Utrecht University">
          <img
            src="/logos/utrechtuniversity-small.webp"
            alt="Utrecht University"
            class="h-[7rem] w-auto translate-y-3"
            loading="lazy"
            decoding="async"
          />
        </a>
      </div>
    </div>
  </div>
</section>
