---
/**
 * TeamMemberCard Component
 *
 * Renders a single team member in either grid (compact card) or list (full-row) layout.
 *
 * Grid layout: compact centred card with photo circle, name, affiliation, links.
 *              In grid mode the card is a <button> that opens the member's modal.
 * List layout: horizontal row with larger photo, full name, affiliation, inline
 *              rendered markdown summary, and WP badges.
 *
 * Photo is resolved automatically from `src/assets/team/<slug>.{webp,jpg,jpeg,png}`.
 * If no photo file exists the component falls back to an initials placeholder.
 *
 * @example
 * <TeamMemberCard member={entry} layout="list" />
 * <TeamMemberCard member={entry} layout="grid" />
 */
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { marked } from "marked";

interface Props {
  member: CollectionEntry<"team">;
  /** "list" renders a full-width row (default); "grid" renders a compact card */
  layout?: "list" | "grid";
}

const { member, layout = "list" } = Astro.props;
const { name, affiliation, affiliationShort, links, workPackages, summary } =
  member.data;

const slug = member.id;
const isGrid = layout === "grid";

// ---- Photo lookup via slug -----------------------------------------------
// Eagerly import all team photos so Astro can optimise them.
const photoGlob = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/team/*.{webp,jpg,jpeg,png}",
  { eager: true }
);

// Find the first extension that matches this slug.
const extensions = ["webp", "jpg", "jpeg", "png"];
let photoSrc: ImageMetadata | undefined;
for (const ext of extensions) {
  const key = `/src/assets/team/${slug}.${ext}`;
  if (photoGlob[key]) {
    photoSrc = photoGlob[key].default;
    break;
  }
}

// ---- Initials + placeholder colour ----------------------------------------
function getInitials(fullName: string): string {
  const parts = fullName.trim().split(/\s+/);
  if (parts.length === 1) return parts[0].charAt(0).toUpperCase();
  return (
    parts[0].charAt(0).toUpperCase() +
    parts[parts.length - 1].charAt(0).toUpperCase()
  );
}

function avatarColor(fullName: string): string {
  const palette = [
    "bg-[#cce5f0]",
    "bg-[#d4edda]",
    "bg-[#fff3cd]",
    "bg-[#f8d7da]",
    "bg-[#d1ecf1]",
    "bg-[#e2d9f3]",
    "bg-[#fde2c8]",
    "bg-[#c8e6c9]",
  ];
  let hash = 0;
  for (let i = 0; i < fullName.length; i++) {
    hash = (hash * 31 + fullName.charCodeAt(i)) & 0xffffff;
  }
  return palette[hash % palette.length];
}

const initials = getInitials(name);
const placeholderBg = avatarColor(name);

// ---- Render markdown summary -----------------------------------------------
// All anchors rendered from the markdown summary open in a new tab.
const summaryHtml = summary
  ? marked
      .parse(summary)
      .toString()
      .replace(/<a /g, '<a target="_blank" rel="noopener noreferrer" ')
  : "";

// ---- Photo size (uniform across layouts) -----------------------------------
const photoSize = 175;
---

{isGrid ? (
  <button
    type="button"
    id={slug}
    data-modal-id={`modal-${slug}`}
    aria-haspopup="dialog"
    class="flex flex-col items-center text-center gap-3 w-full rounded-lg p-3 -mx-3 transition-shadow hover:shadow-md focus-visible:shadow-md focus-visible:ring-2 focus-visible:ring-[var(--color-ring)] focus-visible:ring-offset-2 focus-visible:outline-none cursor-pointer bg-transparent border-0"
  >
    <!-- Circle photo or initials placeholder -->
    <div
      class="rounded-full overflow-hidden flex items-center justify-center shrink-0"
      style={`width: ${photoSize}px; height: ${photoSize}px;`}
    >
      {photoSrc ? (
        <Image
          src={photoSrc}
          alt={`Photo of ${name}`}
          width={photoSize}
          height={photoSize}
          densities={[1.5, 2]}
          quality={85}
          class="w-full h-full object-cover"
        />
      ) : (
        <div
          class:list={[
            "w-full h-full flex items-center justify-center font-semibold text-foreground/70 text-2xl",
            placeholderBg,
          ]}
          aria-hidden="true"
        >
          {initials}
        </div>
      )}
    </div>

    <!-- Name + affiliation (links live in the modal in grid view) -->
    <div class="flex flex-col items-center gap-1 w-full">
      <h3 class="text-lg font-semibold leading-tight">{name}</h3>
      <p class="text-base text-muted-foreground">{affiliationShort ?? affiliation}</p>
      {workPackages.some((w) => w.role) && (
        <div class="flex flex-wrap justify-center gap-1.5 mt-1">
          {workPackages
            .filter((w) => w.role)
            .map(({ wp, role }) => (
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-primary/15 text-primary">
                {role === "standalone"
                ? wp
                : `${wp} ${role!.charAt(0).toUpperCase()}${role!.slice(1)}`}
              </span>
            ))}
        </div>
      )}
    </div>
  </button>
) : (
  <article id={slug} class="flex items-start gap-5 py-8 border-b border-border last:border-b-0">
    <!-- Circle photo or initials placeholder -->
    <div
      class="rounded-full overflow-hidden flex items-center justify-center shrink-0"
      style={`width: ${photoSize}px; height: ${photoSize}px;`}
    >
      {photoSrc ? (
        <Image
          src={photoSrc}
          alt={`Photo of ${name}`}
          width={photoSize}
          height={photoSize}
          densities={[1.5, 2]}
          quality={85}
          class="w-full h-full object-cover"
        />
      ) : (
        <div
          class:list={[
            "w-full h-full flex items-center justify-center font-semibold text-foreground/70 text-xl",
            placeholderBg,
          ]}
          aria-hidden="true"
        >
          {initials}
        </div>
      )}
    </div>

    <div class="flex-1 min-w-0">
      <h3 class="text-xl font-semibold leading-tight">{name}</h3>
      <div class="flex items-baseline flex-wrap gap-x-3 gap-y-1 mt-0.5">
        <p class="text-lg text-muted-foreground">{affiliation}</p>
        {workPackages
          .filter((w) => w.role)
          .map(({ wp, role }) => (
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-primary/15 text-primary">
              {role === "standalone"
                ? wp
                : `${wp} ${role!.charAt(0).toUpperCase()}${role!.slice(1)}`}
            </span>
          ))}
      </div>

      {summaryHtml && (
        <div class="prose prose-lg prose-neutral dark:prose-invert max-w-none mt-2 text-muted-foreground">
          <Fragment set:html={summaryHtml} />
        </div>
      )}

      {workPackages.some((w) => !w.role) && (
        <div class="flex flex-wrap gap-1.5 mt-2">
          {workPackages
            .filter((w) => !w.role)
            .map(({ wp }) => (
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-muted text-muted-foreground">
                {wp}
              </span>
            ))}
        </div>
      )}

      {links.length > 0 && (
        <div class="flex items-center gap-3 flex-wrap mt-3">
          {links.map((link) => (
            <a
              href={link.url}
              target={link.type === "email" ? undefined : "_blank"}
              rel={link.type === "email" ? undefined : "noopener noreferrer"}
              class="text-muted-foreground hover:text-primary transition-colors"
              aria-label={`${name} on ${link.type}`}
            >
              {link.type === "orcid" && <Fragment set:html={`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="${iconClass}" fill="currentColor" aria-hidden="true"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947 0 .525-.422.947-.947.947-.525 0-.946-.422-.946-.947 0-.525.421-.947.946-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/></svg>`} />}
              {link.type === "scholar" && <Fragment set:html={`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="${iconClass}" fill="currentColor" aria-hidden="true"><path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 10a8 8 0 0 1 7.162 3.44L24 9.5z"/></svg>`} />}
              {link.type === "bluesky" && <Fragment set:html={`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 360 320" class="${iconClass}" fill="currentColor" aria-hidden="true"><path d="M180 141.964C163.699 110.262 126.468 55.219 87.219 29.482 64.786 15.098 43.344 7.289 24.13 13.531 1.044 21.044-2.664 51.57 3.386 81.43c7.52 37.066 36.76 65.416 72.68 71.355-4.86.71-9.36 2.05-13.456 4.048-17.315 8.512-20.44 29.578-12.012 48.43C71.05 243.91 136.83 284.74 180 284.74c43.17 0 108.95-40.83 129.402-79.477 8.428-18.852 5.303-39.918-12.012-48.43-4.096-1.998-8.596-3.338-13.456-4.048 35.92-5.939 65.16-34.289 72.68-71.355 6.05-29.86 2.342-60.386-20.744-67.899-19.214-6.242-40.656 1.567-63.089 15.951C233.532 55.219 196.301 110.262 180 141.964z"/></svg>`} />}
              {link.type === "homepage" && <Fragment set:html={`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="${iconClass}" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`} />}
              {link.type === "email" && <Fragment set:html={`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="${iconClass}" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`} />}
              {link.type === "linkedin" && <Fragment set:html={`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="${iconClass}" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>`} />}
              {link.type === "github" && <Fragment set:html={`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="${iconClass}" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`} />}
              {link.type === "twitter" && <Fragment set:html={`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="${iconClass}" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`} />}
              {link.type === "researchgate" && <Fragment set:html={`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="${iconClass}" fill="currentColor" aria-hidden="true"><!-- Font Awesome Free 6 (CC BY 4.0): https://fontawesome.com/license/free --><path d="M0 32v448h448V32H0zm262.2 334.4c-6.6 3-33.2 6-50-14.2-9.2-10.6-25.3-33.3-42.2-63.6-8.9 0-14.7 0-21.4-.6v46.4c0 23.5 6 21.2 25.8 23.9v8.1c-6.9-.3-23.1-.8-35.6-.8-13.1 0-26.1.6-33.6.8v-8.1c15.5-2.9 22-1.3 22-23.9V225c0-22.6-6.4-21-22-23.9V193c25.8 1 53.1-.6 70.9-.6 31.7 0 55.9 14.4 55.9 45.6 0 21.1-16.7 42.2-39.2 47.5 13.6 24.2 30 45.6 42.2 58.9 7.2 7.8 17.2 14.7 27.2 14.7v7.3zm22.9-135c-23.3 0-32.2-15.7-32.2-32.2V167c0-12.2 8.8-30.4 34-30.4s30.4 17.9 30.4 17.9l-10.7 7.2s-5.5-12.5-19.7-12.5c-7.9 0-19.7 7.3-19.7 19.7v26.8c0 13.4 6.6 23.3 17.9 23.3 14.1 0 21.5-10.9 21.5-26.8h-17.9v-10.7h30.4c0 20.5 4.7 49.9-34 49.9zm-116.5 44.7c-9.4 0-13.6-.3-20-.8v-69.7c6.4-.6 15-.6 22.5-.6 23.3 0 37.2 12.2 37.2 34.5 0 21.9-15 36.6-39.7 36.6z"/></svg>`} />}
            </a>
          ))}
        </div>
      )}
    </div>
  </article>
)}
