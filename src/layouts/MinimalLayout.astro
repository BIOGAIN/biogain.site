---
/**
 * Minimal Layout
 *
 * Full-width layout without header or footer.
 * Ideal for standalone pages like 404, maintenance, or landing pages
 * that need complete control over the viewport.
 *
 * @example
 * ```astro
 * <MinimalLayout title="Page Not Found">
 *   <div class="flex items-center justify-center min-h-screen">
 *     <h1>404</h1>
 *   </div>
 * </MinimalLayout>
 * ```
 */
import { ClientRouter } from "astro:transitions";
import "@/styles/globals.css";
import SEO from "@/components/SEO.astro";
import FontPreload from "@/components/FontPreload.astro";
import ThemeScript from "@/components/ThemeScript.astro";
import { withBase } from "@/lib/utils";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const { 
  title, 
  description = "Enabling biodiversity-positive transformation of energy planning towards climate neutrality",
  image,
  noindex = false,
} = Astro.props;

const fullTitle = `${title} | BIOGAIN`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <FontPreload />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <title>{fullTitle}</title>
    <SEO 
      title={fullTitle}
      description={description}
      image={image}
      noindex={noindex}
    />
    <ClientRouter />
    <ThemeScript />
  </head>
  <body class="min-h-screen antialiased">
    <a href="#main-content" class="sr-only focus-visible:not-sr-only focus-visible:absolute focus-visible:top-4 focus-visible:left-4 focus-visible:z-50 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium">
      Skip to content
    </a>
    <main id="main-content" class="min-h-screen" data-pagefind-ignore>
      <slot />
    </main>
  </body>
</html>
