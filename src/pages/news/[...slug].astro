---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, getEntry, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { getNewsUrl, getNewsSlug } from "@/lib/news";
import { withBase } from "@/lib/utils";
import TeamMemberCard from "@/components/TeamMemberCard.astro";

export async function getStaticPaths() {
  const newsPosts = await getCollection("news");
  const sortedPosts = newsPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );

  return sortedPosts.map((post, index) => {
    const date = new Date(post.data.pubDate);
    const year = date.getUTCFullYear();
    const month = String(date.getUTCMonth() + 1).padStart(2, "0");
    return {
      params: { slug: `${year}/${month}/${getNewsSlug(post)}` },
      props: {
        post,
        prevPost: index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null,
        nextPost: index > 0 ? sortedPosts[index - 1] : null,
      },
    };
  });
}

interface Props {
  post: CollectionEntry<"news">;
  prevPost: CollectionEntry<"news"> | null;
  nextPost: CollectionEntry<"news"> | null;
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

// Resolve linked team members
const linkedTeamMembers = await Promise.all(
  (post.data.team ?? []).map((ref) => getEntry(ref))
);
const teamMembers = linkedTeamMembers.filter(
  (m): m is CollectionEntry<"team"> => m !== undefined
);

// Format date helper
function formatDate(date: Date) {
  return new Date(date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

// NewsArticle structured data
const siteOrigin = (Astro.site ?? new URL("https://biogain-project.eu")).href.replace(/\/$/, "");
const articleUrl = new URL(Astro.url.pathname, Astro.site ?? "https://biogain-project.eu").href;
const newsArticleJsonLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  author: { "@type": "Person", name: post.data.author },
  publisher: {
    "@type": "Organization",
    name: "BIOGAIN",
    logo: { "@type": "ImageObject", url: `${siteOrigin}/cover.png` },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": articleUrl },
  ...(post.data.image ? { image: new URL(post.data.image.src, siteOrigin).href } : {}),
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedTime={post.data.pubDate}
  author={post.data.author}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(newsArticleJsonLd)} />
  <article class="px-6 pb-12">
    <div class="container max-w-3xl mx-auto pt-12 mb-8">
      <a
        href={withBase("/news")}
        class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="mr-2"
          aria-hidden="true"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Back to News
      </a>
    </div>

    <header class="mb-12">
      <div class="container max-w-3xl mx-auto mb-8 space-y-4">
        <h1 class="text-5xl font-bold tracking-tight">{post.data.title}</h1>

        <p class="text-xl text-muted-foreground">{post.data.description}</p>

        <div class="flex items-center gap-4 text-sm text-muted-foreground pt-2">
          <time datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
          <span>•</span>
          <span>{post.data.author}</span>
        </div>

        {
          post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 pt-2">
              {post.data.tags.map((tag) => (
                <a
                  href={withBase(`/tags/${tag}`)}
                  class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary hover:bg-primary/20 transition-colors"
                >
                  {tag}
                </a>
              ))}
            </div>
          )
        }
      </div>

      <div class="container max-w-5xl mx-auto">
        <figure class="m-0">
          <div class="w-full aspect-[4/3] bg-gradient-to-br from-primary/20 via-primary/10 to-transparent relative overflow-hidden rounded-lg">
          {post.data.image ? (
            <Image
              src={post.data.image}
              alt={post.data.imageCaption ?? post.data.title}
              class="w-full h-full object-cover"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="64"
                height="64"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-primary/40"
                aria-hidden="true"
              >
                <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect>
                <circle cx="9" cy="9" r="2"></circle>
                <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
              </svg>
            </div>
          )}
          </div>
          {post.data.image && post.data.imageCaption && (
            <figcaption class="text-sm text-muted-foreground text-center mt-3 italic">
              {post.data.imageCaption}
            </figcaption>
          )}
        </figure>
      </div>
    </header>

    <div class="container max-w-3xl mx-auto">
      <div class="prose prose-neutral dark:prose-invert max-w-none">
        <Content />
      </div>

      <!-- Post contributors block: only shown when team members are linked to this article -->
      {teamMembers.length > 0 && (
        <aside class="mt-12 pt-8 border-t" aria-label="Post contributors">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground mb-2">
            Post contributors
          </h2>
          <div class="space-y-0">
            {teamMembers.map((member) => (
              <TeamMemberCard member={member} layout="list" compact />
            ))}
          </div>
        </aside>
      )}

      <footer class="mt-12 pt-8 border-t">
        <nav class="flex items-center justify-between gap-8">
          {prevPost ? (
            <a
              href={withBase(getNewsUrl(prevPost))}
              class="group flex-1 text-left"
            >
              <div class="text-xs text-muted-foreground mb-1">Previous</div>
              <div class="text-sm font-medium group-hover:text-primary transition-colors">
                {prevPost.data.title}
              </div>
            </a>
          ) : (
            <div class="flex-1"></div>
          )}

          <a
            href={withBase("/news")}
            class="inline-flex items-center text-sm text-muted-foreground hover:text-primary transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="mr-2"
              aria-hidden="true"
            >
              <rect width="3" height="3" x="3" y="3" rx="1"></rect>
              <rect width="3" height="3" x="10" y="3" rx="1"></rect>
              <rect width="3" height="3" x="17" y="3" rx="1"></rect>
              <rect width="3" height="3" x="3" y="10" rx="1"></rect>
              <rect width="3" height="3" x="10" y="10" rx="1"></rect>
              <rect width="3" height="3" x="17" y="10" rx="1"></rect>
              <rect width="3" height="3" x="3" y="17" rx="1"></rect>
              <rect width="3" height="3" x="10" y="17" rx="1"></rect>
              <rect width="3" height="3" x="17" y="17" rx="1"></rect>
            </svg>
            All news
          </a>

          {nextPost ? (
            <a
              href={withBase(getNewsUrl(nextPost))}
              class="group flex-1 text-right"
            >
              <div class="text-xs text-muted-foreground mb-1">Next</div>
              <div class="text-sm font-medium group-hover:text-primary transition-colors">
                {nextPost.data.title}
              </div>
            </a>
          ) : (
            <div class="flex-1"></div>
          )}
        </nav>
      </footer>
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Inline <figure> blocks emitted by the rehype-figure-caption plugin
     from the markdown pattern `![](img)` followed by `*caption*`. */
  .prose figure > img {
    margin-bottom: 0 !important;
  }
  .prose figure > figcaption {
    margin-top: 0.25rem !important;
    text-align: center;
    font-size: 0.875rem;
    font-style: italic;
    color: var(--color-muted-foreground, hsl(var(--muted-foreground)));
  }
</style>
