---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/sections/Hero.astro";
import HeroSplit from "@/components/sections/HeroSplit.astro";
import heroBg from "@/assets/20250829_2-Muigg Philipp-Expanded.jpg";
import heroSplitImage from "@/assets/BIOGAIN_Image_PR.jpg";
import LogoCloud from "@/components/sections/LogoCloud.astro";
import LatestNews from "@/components/sections/LatestNews.astro";
---

<BaseLayout title="Biodiversity Net-Gain for Renewable Energy Planning" description="BIOGAIN is a European Biodiversa+ research project using AI-supported biodiversity data to help plan wind and solar energy for a measurable net-gain for nature.">
  <Hero
    title="BIOGAIN"
    titleAsLogo
    subtitle="Enabling biodiversity-positive transformation of energy planning towards climate neutrality"
    backgroundImage={heroBg}
    backgroundCredit="Photo by Philipp Muigg"
  />

  <HeroSplit
    tagline="About BIOGAIN"
    taglineAsPill={false}
    title="<em>Nature gain</em> at the heart of energy planning."
    subtitle="BIOGAIN investigates how Europe can plan renewable energy in a crowded landscape while working towards a biodiversity <em>net gain</em>. We bring together AI-assisted monitoring and novel biodiversity datasets &mdash; from acoustics and satellites to UAVs and environmental DNA &mdash; to fill the data gaps planners face today. Through serious games, choice experiments, and collaborative decision analyses across five universities and three case-study regions, we test how better data can tip planning toward nature-positive outcomes."
    primaryCta={{ href: "/about", label: "Learn More" }}
    image={{ src: heroSplitImage, alt: "BIOGAIN project imagery" }}
  />
  {/* Secondary CTA disabled for now — re-enable once case-study regions page is live:
       secondaryCta={{ href: "/case-studies", label: "Case-Study Regions" }}
  */}

<LatestNews />

<LogoCloud />

</BaseLayout>
