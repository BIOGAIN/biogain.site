---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/sections/Hero.astro";
import HeroSplit from "@/components/sections/HeroSplit.astro";
import heroBg from "@/assets/benoit-deschasaux-unsplash-hero.webp";
import LogoCloud from "@/components/sections/LogoCloud.astro";
import Features from "@/components/sections/Features.astro";
import AIFeature from "@/components/sections/AIFeature.astro";
import Stats from "@/components/sections/Stats.astro";
import LatestNews from "@/components/sections/LatestNews.astro";

const features = [
  {
    title: "Astro.js Powered",
    description: "Built with Astro for lightning-fast performance and optimal SEO out of the box.",
    icon: "zap",
  },
  {
    title: "shadcn/ui Components",
    description: "Beautiful, accessible components built with Radix UI and Tailwind CSS.",
    icon: "shield",
  },
  {
    title: "TypeScript Ready",
    description: "Full TypeScript support for type-safe development and better DX.",
    icon: "chart",
  },
  {
    title: "Dark Mode",
    description: "Built-in dark mode support with seamless theme switching.",
    icon: "users",
  },
  {
    title: "Responsive Design",
    description: "Mobile-first approach ensuring perfect display on all devices.",
    icon: "globe",
  },
  {
    title: "Ready to Deploy",
    description: "Optimized for Vercel, Netlify, and other modern hosting platforms.",
    icon: "lock",
  },
];
---

<BaseLayout title="Home" description="Enabling biodiversity-positive transformation of energy planning towards climate neutrality">
  <Hero
    title="BIOGAIN"
    titleAsLogo
    subtitle="Enabling biodiversity-positive transformation of energy planning towards climate neutrality"
    backgroundImage={heroBg}
  />

  <HeroSplit
    tagline="About BIOGAIN"
    taglineAsPill={false}
    title="<em>Nature gain</em> at the heart of energy planning."
    subtitle="BIOGAIN investigates how Europe can plan renewable energy in a crowded landscape while working towards a biodiversity <em>net gain</em>. We bring together AI-assisted monitoring and novel biodiversity datasets &mdash; from acoustics and satellites to UAVs and environmental DNA &mdash; to fill the data gaps planners face today. Through serious games, choice experiments, and collaborative decision analyses across five universities and three case-study regions, we test how better data can tip planning toward nature-positive outcomes."
    primaryCta={{ href: "/about", label: "Learn More" }}
    image={{ src: "/BIOGAIN_Image_PR.jpg", alt: "BIOGAIN project imagery" }}
  />
  {/* Secondary CTA disabled for now — re-enable once case-study regions page is live:
       secondaryCta={{ href: "/case-studies", label: "Case-Study Regions" }}
  */}

<LatestNews />

<LogoCloud />

</BaseLayout>
