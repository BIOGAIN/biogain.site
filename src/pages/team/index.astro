---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import TeamMemberCard from "@/components/TeamMemberCard.astro";
import TeamMemberModal from "@/components/TeamMemberModal.astro";
import LogoCloud from "@/components/sections/LogoCloud.astro";

// Fetch all team members
const allMembers = await getCollection("team");

// Sort helpers
function getSurname(name: string): string {
  const parts = name.trim().split(/\s+/);
  return parts[parts.length - 1].toLowerCase();
}

// ---- Role-aware sort key ----------------------------------------------------
// Tier 0: project coordinator(s) — Alexandra at the top.
// Tier 1: WP lead / co-lead — sorted by WP number, with lead before co-lead.
// Tier 2: everyone else — alphabetical by surname (fallback applies in all tiers).
function getRoleSortKey(
  member: CollectionEntry<"team">
): [number, number, number, string] {
  const wps = member.data.workPackages;
  const surname = getSurname(member.data.name);

  if (
    wps.some(
      (w) => w.role === "standalone" && /coordinator/i.test(w.wp)
    )
  ) {
    return [0, 0, 0, surname];
  }

  const leadEntry = wps.find(
    (w) => w.role === "lead" || w.role === "co-lead"
  );
  if (leadEntry) {
    const wpNum = parseInt(leadEntry.wp.replace(/\D/g, ""), 10) || 999;
    const roleOrder = leadEntry.role === "lead" ? 0 : 1;
    return [1, wpNum, roleOrder, surname];
  }

  return [2, 0, 0, surname];
}

function compareByRoleThenSurname(
  a: CollectionEntry<"team">,
  b: CollectionEntry<"team">
): number {
  const ka = getRoleSortKey(a);
  const kb = getRoleSortKey(b);
  for (let i = 0; i < ka.length; i++) {
    if (ka[i] < kb[i]) return -1;
    if (ka[i] > kb[i]) return 1;
  }
  return 0;
}

const sortedAlphabetically = [...allMembers].sort((a, b) =>
  getSurname(a.data.name).localeCompare(getSurname(b.data.name), "en")
);

const sortedByRole = [...allMembers].sort(compareByRoleThenSurname);

// Group by affiliation. Members within each group inherit the role-first order
// from sortedByRole, so each affiliation lists its leaders (coordinator, then
// WP leads/co-leads by number) before the alphabetical remainder.
const affiliationOrder = [
  "BOKU University",
  "Technische Universität Berlin",
  "Wrocław University of Environmental and Life Sciences",
  "Aalborg University",
  "Utrecht University",
];

function affiliationSortIndex(affiliation: string): number {
  const idx = affiliationOrder.indexOf(affiliation);
  return idx === -1 ? affiliationOrder.length : idx;
}

const groupedByAffiliation = sortedByRole.reduce<
  Map<string, CollectionEntry<"team">[]>
>((acc, member) => {
  const aff = member.data.affiliation;
  if (!acc.has(aff)) acc.set(aff, []);
  acc.get(aff)!.push(member);
  return acc;
}, new Map());

const sortedGroups = [...groupedByAffiliation.entries()].sort(
  ([a], [b]) => affiliationSortIndex(a) - affiliationSortIndex(b)
);

// Two sections for the role view: leaders (tier 0 + 1) vs. everyone else (tier 2)
function isLeader(member: CollectionEntry<"team">): boolean {
  return getRoleSortKey(member)[0] < 2;
}

const roleSections: { title: string; members: CollectionEntry<"team">[] }[] = [
  {
    title: "Work package leaders",
    members: sortedByRole.filter(isLeader),
  },
  {
    title: "Team members",
    members: sortedByRole.filter((m) => !isLeader(m)),
  },
];
---

<BaseLayout
  title="Team"
  description="Meet the researchers and practitioners behind BIOGAIN — a European consortium working on biodiversity-positive energy planning."
>
  <!--
    Anti-FOUC: apply saved sort + view before first paint so the page
    never flashes in the wrong state.
  -->
  <script is:inline>
    (function () {
      try {
        var sort = localStorage.getItem("team-sort") || "alpha";
        var view = localStorage.getItem("team-view") || "grid";
        document.documentElement.dataset.teamSort = sort;
        document.documentElement.dataset.teamView = view;
      } catch (_) {}
    })();
  </script>

  <div class="py-20 px-4 sm:px-6">
    <div class="container max-w-5xl mx-auto">
    <!-- Page header -->
    <div class="mb-12">
      <h1 class="text-7xl font-bold tracking-tight mb-8">Team</h1>
      <p class="text-xl text-muted-foreground max-w-2xl">
        The BIOGAIN consortium brings together researchers and practitioners
        from five European universities, working together to advance
        biodiversity-positive energy planning.
      </p>
    </div>

    <div class="mb-16">
      <LogoCloud linkMode="team-affiliation" bordered={false} align="left" />
    </div>

    <!-- Controls row: sort (left) + view toggle (right) -->
    <div
      class="flex items-center justify-between gap-4 mb-12 flex-wrap"
      role="group"
      aria-label="Team display controls"
    >
      <!-- Sort buttons (left) -->
      <div class="flex items-center flex-wrap gap-2">
        <span class="text-sm text-muted-foreground mr-1">Sort by:</span>
        <button
          id="sort-alphabetical"
          class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors border border-border"
          aria-pressed="true"
        >
          Alphabetical
        </button>
        <button
          id="sort-affiliation"
          class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors border border-border"
          aria-pressed="false"
        >
          Affiliation
        </button>
        <button
          id="sort-role"
          class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors border border-border"
          aria-pressed="false"
        >
          Role
        </button>
      </div>

      <!-- View toggle (right) -->
      <div class="flex items-center flex-wrap gap-2">
        <span class="text-sm text-muted-foreground mr-1">View:</span>
        <button
          id="view-list-btn"
          class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors border border-border"
          aria-pressed="true"
          aria-label="List view"
        >
          <!-- List icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            class="w-4 h-4 inline-block"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="8" y1="6" x2="21" y2="6"></line>
            <line x1="8" y1="12" x2="21" y2="12"></line>
            <line x1="8" y1="18" x2="21" y2="18"></line>
            <line x1="3" y1="6" x2="3.01" y2="6"></line>
            <line x1="3" y1="12" x2="3.01" y2="12"></line>
            <line x1="3" y1="18" x2="3.01" y2="18"></line>
          </svg>
          <span class="ml-1">List</span>
        </button>
        <button
          id="view-grid-btn"
          class="px-4 py-1.5 rounded-full text-sm font-medium transition-colors border border-border"
          aria-pressed="false"
          aria-label="Grid view"
        >
          <!-- Grid icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            class="w-4 h-4 inline-block"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="3" width="7" height="7"></rect>
            <rect x="14" y="3" width="7" height="7"></rect>
            <rect x="14" y="14" width="7" height="7"></rect>
            <rect x="3" y="14" width="7" height="7"></rect>
          </svg>
          <span class="ml-1">Grid</span>
        </button>
      </div>
    </div>

    <!--
      Four rendered containers:
        alpha-list  — alphabetical, list layout
        alpha-grid  — alphabetical, grid layout
        affil-list  — by affiliation, list layout
        affil-grid  — by affiliation, grid layout

      JavaScript shows exactly one at a time, matching current sort + view.
    -->

    <!-- Alphabetical · List -->
    <div id="view-alpha-list" class="hidden space-y-0">
      {
        sortedAlphabetically.map((member) => (
          <TeamMemberCard member={member} layout="list" />
        ))
      }
    </div>

    <!-- Alphabetical · Grid (default view on first visit) -->
    <div
      id="view-alpha-grid"
      class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-x-6 gap-y-10"
    >
      {
        sortedAlphabetically.map((member) => (
          <TeamMemberCard member={member} layout="grid" />
        ))
      }
    </div>

    <!-- Affiliation · List -->
    <div id="view-affil-list" class="hidden space-y-0">
      {
        sortedGroups.map(([affiliation, items]) => {
          const short = items[0].data.affiliationShort;
          const country = items[0].data.country;
          const anchorId = short
            ? `affiliation-${short.toLowerCase().replace(/\s+/g, "-")}`
            : undefined;
          return (
            <section id={anchorId} class="mb-12 last:mb-0 scroll-mt-24">
              <div class="mb-6 pb-3 border-b border-border">
                <h2 class="text-2xl font-semibold">{affiliation}</h2>
                {(short || country) && (
                  <p class="text-sm text-muted-foreground mt-1">
                    {[short, country].filter(Boolean).join(" · ")}
                  </p>
                )}
              </div>
              <div class="space-y-0">
                {items.map((member) => (
                  <TeamMemberCard member={member} layout="list" />
                ))}
              </div>
            </section>
          );
        })
      }
    </div>

    <!-- Role · List -->
    <div id="view-role-list" class="hidden space-y-0">
      {
        roleSections.map(({ title, members }) =>
          members.length === 0 ? null : (
            <section class="mb-12 last:mb-0">
              <div class="mb-6 pb-3 border-b border-border">
                <h2 class="text-2xl font-semibold">{title}</h2>
              </div>
              <div class="space-y-0">
                {members.map((member) => (
                  <TeamMemberCard member={member} layout="list" />
                ))}
              </div>
            </section>
          )
        )
      }
    </div>

    <!-- Role · Grid -->
    <div id="view-role-grid" class="hidden space-y-16">
      {
        roleSections.map(({ title, members }) =>
          members.length === 0 ? null : (
            <section>
              <div class="mb-8 pb-3 border-b border-border">
                <h2 class="text-2xl font-semibold">{title}</h2>
              </div>
              <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-x-6 gap-y-10">
                {members.map((member) => (
                  <TeamMemberCard member={member} layout="grid" />
                ))}
              </div>
            </section>
          )
        )
      }
    </div>

    <!-- Affiliation · Grid -->
    <div id="view-affil-grid" class="hidden space-y-16">
      {
        sortedGroups.map(([affiliation, items]) => {
          const short = items[0].data.affiliationShort;
          const country = items[0].data.country;
          const anchorId = short
            ? `affiliation-${short.toLowerCase().replace(/\s+/g, "-")}`
            : undefined;
          return (
            <section id={anchorId} class="scroll-mt-24">
              <div class="mb-8 pb-3 border-b border-border">
                <h2 class="text-2xl font-semibold">{affiliation}</h2>
                {(short || country) && (
                  <p class="text-sm text-muted-foreground mt-1">
                    {[short, country].filter(Boolean).join(" · ")}
                  </p>
                )}
              </div>
              <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-x-6 gap-y-10">
                {items.map((member) => (
                  <TeamMemberCard member={member} layout="grid" />
                ))}
              </div>
            </section>
          );
        })
      }
    </div>
    </div>
  </div>

  <!-- Team member modals (one per member, pre-rendered HTML) -->
  {allMembers.map((member) => (
    <TeamMemberModal member={member} />
  ))}
</BaseLayout>

<script>
  function initTeamControls() {
    type SortMode = "alpha" | "affil" | "role";
    type ViewMode = "list" | "grid";

    const sortButtons: Record<SortMode, HTMLElement | null> = {
      alpha: document.getElementById("sort-alphabetical"),
      affil: document.getElementById("sort-affiliation"),
      role: document.getElementById("sort-role"),
    };
    const viewButtons: Record<ViewMode, HTMLElement | null> = {
      list: document.getElementById("view-list-btn"),
      grid: document.getElementById("view-grid-btn"),
    };

    // Containers keyed as `${sort}-${view}` → element
    const containers: Record<string, HTMLElement | null> = {
      "alpha-list": document.getElementById("view-alpha-list"),
      "alpha-grid": document.getElementById("view-alpha-grid"),
      "affil-list": document.getElementById("view-affil-list"),
      "affil-grid": document.getElementById("view-affil-grid"),
      "role-list": document.getElementById("view-role-list"),
      "role-grid": document.getElementById("view-role-grid"),
    };

    // Bail if any node is missing
    if (
      Object.values(sortButtons).some((b) => !b) ||
      Object.values(viewButtons).some((b) => !b) ||
      Object.values(containers).some((c) => !c)
    ) {
      return;
    }

    const activeClasses = ["bg-primary", "text-primary-foreground"];
    const inactiveClasses = ["bg-background", "text-foreground", "hover:bg-muted"];

    function setActive(btn: HTMLElement) {
      btn.classList.add(...activeClasses);
      btn.classList.remove(...inactiveClasses);
      btn.setAttribute("aria-pressed", "true");
    }

    function setInactive(btn: HTMLElement) {
      btn.classList.remove(...activeClasses);
      btn.classList.add(...inactiveClasses);
      btn.setAttribute("aria-pressed", "false");
    }

    let sortMode: SortMode = "alpha";
    let viewMode: ViewMode = "grid";

    try {
      const savedSort = localStorage.getItem("team-sort");
      const savedView = localStorage.getItem("team-view");
      if (savedSort === "affil" || savedSort === "role") sortMode = savedSort;
      if (savedView === "list") viewMode = savedView;
    } catch (_) {}

    // If we arrived with #affiliation-<short>, force the affiliation sort
    // so the target section is actually rendered before scrolling.
    function syncSortToHash() {
      const hash = window.location.hash.slice(1);
      if (hash.startsWith("affiliation-") && sortMode !== "affil") {
        sortMode = "affil";
      }
    }
    syncSortToHash();

    function applyState() {
      // Show only the matching container
      for (const [key, el] of Object.entries(containers)) {
        if (!el) continue;
        if (key === `${sortMode}-${viewMode}`) {
          el.classList.remove("hidden");
        } else {
          el.classList.add("hidden");
        }
      }

      // Sort buttons
      for (const [mode, btn] of Object.entries(sortButtons)) {
        if (!btn) continue;
        if (mode === sortMode) setActive(btn);
        else setInactive(btn);
      }

      // View buttons
      for (const [mode, btn] of Object.entries(viewButtons)) {
        if (!btn) continue;
        if (mode === viewMode) setActive(btn);
        else setInactive(btn);
      }

      try {
        localStorage.setItem("team-sort", sortMode);
        localStorage.setItem("team-view", viewMode);
      } catch (_) {}
    }

    // Each member's id (and each affiliation-section id) is duplicated across
    // all sort/view containers, so the browser's default hash-anchor scroll
    // can land on a hidden element. Scope the lookup to the container we just
    // showed — this also avoids reading offsetParent before the browser has
    // had a chance to re-run layout after applyState().
    function scrollToHash() {
      const hash = window.location.hash;
      if (!hash || hash.length < 2) return;
      const id = decodeURIComponent(hash.slice(1));
      const visible = containers[`${sortMode}-${viewMode}`];
      const el = visible?.querySelector<HTMLElement>(`[id="${CSS.escape(id)}"]`);
      if (el) {
        // Affiliation sections anchor to the top (so the section header is
        // visible). Member-slug anchors centre the card in the viewport.
        const block = id.startsWith("affiliation-") ? "start" : "center";
        el.scrollIntoView({ block });
      }
    }

    // Wire up clicks
    for (const [mode, btn] of Object.entries(sortButtons) as [SortMode, HTMLElement | null][]) {
      btn?.addEventListener("click", () => {
        sortMode = mode;
        applyState();
      });
    }
    for (const [mode, btn] of Object.entries(viewButtons) as [ViewMode, HTMLElement | null][]) {
      btn?.addEventListener("click", () => {
        viewMode = mode;
        applyState();
      });
    }

    applyState();
    scrollToHash();
    window.addEventListener("hashchange", () => {
      syncSortToHash();
      applyState();
      scrollToHash();
    });

    // Same-page links to /team#... need to be intercepted before Astro's
    // ClientRouter (registered by BaseLayout) handles the click. We use the
    // capture phase and stopImmediatePropagation so the click never reaches
    // ClientRouter. Two cases this fixes:
    //  1. The hash didn't change (e.g. user opens /team#affiliation-aau,
    //     switches to alpha, then clicks the same logo) — no hashchange would
    //     fire, so our hashchange listener would never run.
    //  2. ClientRouter intercepts and would otherwise swallow the navigation.
    document.addEventListener(
      "click",
      (e) => {
        if (
          e.button !== 0 ||
          e.metaKey ||
          e.ctrlKey ||
          e.shiftKey ||
          e.altKey
        ) return;

        const target = e.target as HTMLElement | null;
        const link = target?.closest<HTMLAnchorElement>("a");
        if (!link) return;

        const base = import.meta.env.BASE_URL.replace(/\/$/, "");
        const teamPaths = [`${base}/team`, `${base}/team/`];
        const onTeamPage = teamPaths.includes(location.pathname);
        if (!onTeamPage) return;

        let url: URL;
        try {
          url = new URL(link.href, location.origin);
        } catch {
          return;
        }

        // Only intercept same-document /team links with a hash
        if (
          url.origin !== location.origin ||
          !teamPaths.includes(url.pathname) ||
          !url.hash
        ) return;

        e.preventDefault();
        e.stopImmediatePropagation();

        if (location.hash !== url.hash) {
          history.pushState(null, "", url.hash);
        }
        syncSortToHash();
        applyState();
        scrollToHash();
      },
      true // capture phase — runs before ClientRouter's listener
    );
  }

  initTeamControls();
  document.addEventListener("astro:after-swap", initTeamControls);
</script>

<script>
  // ---- Team member modal wiring ----------------------------------------
  // Opens the correct <dialog> when a grid card button is clicked.
  // Closes on: X button click, backdrop click (click on <dialog> itself), ESC (native).

  function initTeamModals() {
    // Open: clicking any grid card button
    document.querySelectorAll<HTMLButtonElement>("button[data-modal-id]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const dialogId = btn.dataset.modalId;
        if (!dialogId) return;
        const dialog = document.getElementById(dialogId) as HTMLDialogElement | null;
        if (dialog) {
          dialog.showModal();
        }
      });
    });

    // Close: clicking the X button inside each dialog
    document.querySelectorAll<HTMLButtonElement>("button[data-modal-close]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const dialogId = btn.dataset.modalClose;
        if (!dialogId) return;
        const dialog = document.getElementById(dialogId) as HTMLDialogElement | null;
        if (dialog) {
          dialog.close();
        }
      });
    });

    // Close: clicking the backdrop (the <dialog> element itself, not its inner content)
    document.querySelectorAll<HTMLDialogElement>("dialog.team-modal").forEach((dialog) => {
      dialog.addEventListener("click", (e) => {
        if (e.target === dialog) {
          dialog.close();
        }
      });
    });
  }

  initTeamModals();
  document.addEventListener("astro:after-swap", initTeamModals);
</script>
