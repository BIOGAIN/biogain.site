---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Content } from "@/content/pages/about.mdx";
import LogoCloud from "@/components/sections/LogoCloud.astro";
---

<BaseLayout
  title="About"
  description="Learn about the BIOGAIN project — its mission, goals, and the research behind biodiversity-positive energy planning in Europe."
>
  <div class="py-20 px-4 sm:px-6">
    <div class="container max-w-3xl mx-auto">
      <div class="mb-12">
        <h1 class="text-5xl font-bold tracking-tight mb-4">About BIOGAIN</h1>
      </div>
      <div class="prose prose-neutral dark:prose-invert max-w-none">
        <Content />
      </div>
    </div>
  </div>

  <LogoCloud linkMode="team-affiliation" />
</BaseLayout>
