---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Content } from "@/content/pages/output/publications.md";
---

<BaseLayout
  title="Publications"
  description="Scientific publications from the BIOGAIN project on biodiversity-positive energy planning in Europe."
>
  <div class="py-20 px-4 sm:px-6">
    <div class="container max-w-3xl mx-auto">
      <div class="mb-12">
        <h1 class="text-5xl font-bold tracking-tight mb-4">Publications</h1>
      </div>
      <div class="prose prose-neutral dark:prose-invert max-w-none">
        <Content />
      </div>
    </div>
  </div>
</BaseLayout>
