---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Content } from "@/content/pages/output/press-coverage.md";
---

<BaseLayout
  title="Press coverage"
  description="Media coverage and press mentions of the BIOGAIN project."
>
  <div class="py-20 px-4 sm:px-6">
    <div class="container max-w-3xl mx-auto">
      <div class="mb-12">
        <h1 class="text-5xl font-bold tracking-tight mb-4">Press coverage</h1>
      </div>
      <div class="prose prose-neutral dark:prose-invert max-w-none">
        <Content />
      </div>
    </div>
  </div>
</BaseLayout>
